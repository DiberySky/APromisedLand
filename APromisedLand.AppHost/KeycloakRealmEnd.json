        "clientRole": false,
        "containerId": "apromisedland"
      },
      {
        "name": "offline_access",
        "description": "${role_offline-access}",
        "composite": false,
        "clientRole": false,
        "containerId": "apromisedland"
      },
      {
        "name": "uma_authorization",
        "description": "${role_uma_authorization}",
        "composite": false,
        "clientRole": false,
        "containerId": "apromisedland"
      }
    ],
    "client": {}
  },
