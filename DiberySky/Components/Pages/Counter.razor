@page "/counter"

<PageSky Title="Counter">
    <PageContent>
        <p role="status">Current count: @_currentCount</p>

        <button class="btn btn-primary" @onclick="IncrementCount">Click me</button>
    </PageContent>
</PageSky>

@code {
    private int _currentCount = 0;

    private void IncrementCount()
    {
        _currentCount++;
    }

}