@page "/window-size"
@using Microsoft.Maui.Controls
@implements IDisposable

<PageSky Title="当前窗口大小">
    <PageContent>
        <h3>当前窗口大小</h3>
        <p><strong>宽度：</strong>@windowWidth.ToString("F0")</p>
        <p><strong>高度：</strong>@windowHeight.ToString("F0")</p>
    </PageContent>
</PageSky>

@code {
    private double windowWidth;
    private double windowHeight;
    private Window? currentWindow;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            // 获取当前窗口并订阅大小变化事件
            currentWindow = Application.Current?.Windows.FirstOrDefault();
            if (currentWindow != null)
            {
                // 初始值（如果有效）
                if (!double.IsNaN(currentWindow.Width))
                    windowWidth = currentWindow.Width;
                if (!double.IsNaN(currentWindow.Height))
                    windowHeight = currentWindow.Height;

                currentWindow.SizeChanged += OnWindowSizeChanged;
                StateHasChanged();
            }
        }
    }

    private void OnWindowSizeChanged(object? sender, EventArgs e)
    {
        if (currentWindow != null)
        {
            windowWidth = currentWindow.Width;
            windowHeight = currentWindow.Height;
            InvokeAsync(StateHasChanged); // 更新 UI
        }
    }

    public void Dispose()
    {
        if (currentWindow != null)
            currentWindow.SizeChanged -= OnWindowSizeChanged;
    }
}