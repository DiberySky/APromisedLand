@page "/testingapl"

@inject NavigationManager Navigater

<PageSky MaxWidth="MaxWidth.Small" Title="Home" BottomBarVisibled
         BackPage="signinapl">
    <PageContent>
        <MudPaper Class="border-3 border-solid mud-border-success pa-4">
            @for (int i = 0; i < 10; i++)
            {
                <h1>@i</h1>

                <p role="status">Current count: @currentCount</p>

                <button class="btn btn-primary" @onclick="IncrementCount">Click me</button>

                <MudDivider DividerType="DividerType.Middle" />
            }
        </MudPaper>
    </PageContent>
    <BottomBarContent>
        <MudSpacer />
        <MudText Color="Color.Success">武汉浩瀚科技有限公司</MudText>
        <MudSpacer />
    </BottomBarContent>
</PageSky>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}