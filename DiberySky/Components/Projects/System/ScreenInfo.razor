@page "/screen-info"
@using Microsoft.Maui.Devices

<h3>屏幕信息</h3>

<p><strong>逻辑尺寸：</strong>@screenWidth x @screenHeight</p>
<p><strong>屏幕密度：</strong>@density</p>
<p><strong>物理分辨率：</strong>@physicalWidth x @physicalHeight</p>
<p><strong>方向：</strong>@orientation</p>
<p><strong>刷新率：</strong>@refreshRate Hz</p>

@code {
    private double screenWidth;
    private double screenHeight;
    private double density;
    private double physicalWidth;
    private double physicalHeight;
    private string? orientation;
    private double refreshRate;

    protected override void OnInitialized()
    {
        // 获取主显示信息
        var displayInfo = DeviceDisplay.Current.MainDisplayInfo;

        screenWidth = displayInfo.Width;
        screenHeight = displayInfo.Height;
        density = displayInfo.Density;
        physicalWidth = screenWidth * density;
        physicalHeight = screenHeight * density;
        orientation = displayInfo.Orientation.ToString();
        refreshRate = displayInfo.RefreshRate;
    }
}