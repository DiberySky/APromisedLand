@page "/os-info"
@using Microsoft.Maui.Devices

<h3>当前操作系统信息</h3>

<p><strong>平台：</strong>@platformName</p>
<p><strong>设备类型：</strong>@deviceType</p>

@code {
    private string platformName = "未知";
    private string deviceType = "未知";

    protected override void OnInitialized()
    {
        // 判断操作系统
        if (DeviceInfo.Current.Platform == DevicePlatform.Android)
            platformName = "Android";
        else if (DeviceInfo.Current.Platform == DevicePlatform.iOS)
            platformName = "iOS";
        else if (DeviceInfo.Current.Platform == DevicePlatform.WinUI)
            platformName = "Windows";
        else if (DeviceInfo.Current.Platform == DevicePlatform.macOS)
            platformName = "macOS";
        else if (DeviceInfo.Current.Platform == DevicePlatform.Tizen)
            platformName = "Tizen";
        else
            platformName = "其他";

        // 判断设备类型（手机、平板、桌面、电视等）
        // deviceType = DeviceInfo.Current.Idiom switch
        // {
        //     DeviceIdiom.Phone => "手机",
        //     DeviceIdiom.Tablet => "平板",
        //     DeviceIdiom.Desktop => "桌面",
        //     DeviceIdiom.TV => "电视",
        //     DeviceIdiom.Watch => "手表",
        //     _ => "未知"
        // };
    }
}