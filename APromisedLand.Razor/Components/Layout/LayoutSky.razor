@namespace APromisedLand.Razor.Components

@inherits LayoutComponentBase

<MudLayout>
    <MudAppBar Dense Class="mud-theme-primary">
        <MudSpacer />
        <MudText Color="Color.Success">@ProjectService.Copyright</MudText>
        <MudSpacer />
    </MudAppBar>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@* Required *@
<MudThemeProvider IsDarkMode DefaultScrollbar />
<MudPopoverProvider />
@* Needed for dialogs *@
<MudDialogProvider />
@* Needed for snackbars *@
<MudSnackbarProvider />

@code {
    protected override void OnInitialized()
    {
        base.OnInitialized();

#if DEBUG
        ProjectService.Debug = true;
#endif
    }
}
