@namespace APromisedLand.Razor.Components
@using APromisedLand.Razor.Helper
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageSky Title="@Title" ArrowBackVisibled="false"
         BottomBarVisibled="true"
         StartButtonVisibled="true"
         OnStartClick="e => OnStartClick.InvokeAsync()">
    <PageContent>
        <MudContainer Class="py-4 px-0 mx-0 mt-8" MaxWidth="MaxWidth.Medium">
            <MudCard Outlined="true">
                <MudCardHeader Class="mud-theme-success">
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">登录</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Login"
                                       Color="Color.Warning" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudForm @ref="_form">
                        <MudStack Spacing="2" Class="px-8">
                            <MudTextField T="string" @bind-Value="@_user" Required
                                          Variant="Variant.Outlined" Label="用户" />

                            <PasswordSky @ref="_passwordField" Variant="Variant.Outlined" />
                        </MudStack>
                    </MudForm>
                </MudCardContent>
                <MudCardActions>
                    <MudSpacer />
                    <ButtonLoadingSky Text="登录" Color="Color.Primary" Size="Size.Small"
                                      Class="mr-8 mb-2"
                                      Variant="Variant.Filled"
                                      FuncClick="OnSubmitClick" />
                </MudCardActions>
            </MudCard>
        </MudContainer>
    </PageContent>
</PageSky>

@code {
    MudForm? _form;
    PasswordSky? _passwordField;
    string? _user;

    [Parameter] public required string Title { get; set; }
    [Parameter] public EventCallback<SignInUser> OnSignInClick { get; set; }

    [Parameter] public EventCallback OnStartClick { get; set; }
    [Parameter] public EventCallback OnBackClick { get; set; }

    protected override void OnInitialized()
    {
        base.OnInitialized();
#if DEBUG
        _user = "tian";
#endif
    }
    private async Task OnSubmitClick()
    {
        if (_form == null || _passwordField == null
            || string.IsNullOrEmpty(_user) || string.IsNullOrEmpty(_passwordField.Password))
        {
            return;
        }

        try
        {
            await _form.ValidateAsync();

            if (_form.IsValid == false) return;

            var logonUser = new SignInUser { UserName = _user, Password = _passwordField.Password };

            await OnSignInClick.InvokeAsync(logonUser);
        }
        catch (Exception e)
        {
            Snackbar.Details("登录失败。", e.Message, DialogService);
        }
    }
}
