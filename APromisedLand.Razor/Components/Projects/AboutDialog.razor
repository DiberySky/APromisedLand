        <MudContainer Class="d-flex justify-center py-4" MaxWidth="MaxWidth.Small">
            <MudStack Row AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h6" Color="Color.Default">版本：</MudText>
                <MudText Color="Color.Success">@ProjectHelper.Version</MudText>
            </MudStack>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudSpacer />
        <MudText Color="Color.Primary">@ProjectHelper.Copyright</MudText>
        <MudSpacer />
    </DialogActions>
</DialogSky>

